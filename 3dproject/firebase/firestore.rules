rules_version = '2';
// ============================================================
//  Reglas de seguridad de Firestore - 3DProject
//  Pegalas en: Consola Firebase -> Firestore Database ->
//  pestana "Reglas" -> "Publicar".
// ------------------------------------------------------------
//  - Pedidos: el ADMIN (con sesion) crea, lista y edita.
//    El CLIENTE puede CONSULTAR su pedido por su codigo (get),
//    pero NO listar todos.
//  - Etapas: lectura publica (portal de seguimiento); solo el
//    admin las modifica.
//  - Feedback y datos de PrintFlow/3DPlanner: solo con sesion.
// ============================================================
service cloud.firestore {
  match /databases/{database}/documents {

    match /orders/{orderId} {
      allow get:   if true;
      allow list:  if request.auth != null;
      allow write: if request.auth != null;

      match /steps/{stepId} {
        allow read:  if true;
        allow write: if request.auth != null;
      }
    }

    match /presets/{id} {
      allow read, write: if request.auth != null;
    }

    match /feedback/{docId} {
      allow read, write: if request.auth != null;
    }

    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
